# ============================================================
#  IELTS Speaking App – Root .gitignore
# ============================================================

# ─── ML Model Files (PENTING: terlalu besar untuk GitHub) ──
# Semua file model di-ignore karena > 100MB (batas GitHub)
# Simpan model di Google Drive / HuggingFace Hub
backend/models/

# Catch-all untuk semua file model biner di mana pun
*.safetensors
*.bin
*.pt
*.pth

# ─── Secrets & Environment Variables ───────────────────────
.env
.env.*
!.env.example

# ─── Python / Backend ──────────────────────────────────────
# Virtual environments
venv/
venv_rules/
.venv/
env/
ENV/

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.pyc

# Distribution / packaging
*.egg-info/
dist/
build/
.eggs/
*.wheel
*.whl

# Type checking
.mypy_cache/
.dmypy.json
dmypy.json
.pytype/

# Testing
.pytest_cache/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover

# Logs
*.log

# ─── Node.js / Frontend ────────────────────────────────────
node_modules/
frontend/node_modules/

# Next.js build output
.next/
frontend/.next/
out/
frontend/out/

# Next.js cache
frontend/.swc/

# npm / yarn / pnpm
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.tgz
.yarn/cache
.yarn/unplugged
.yarn/install-state.gz
.pnp.*

# TypeScript build info
*.tsbuildinfo
next-env.d.ts

# ─── IDE / Editor ──────────────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ─── OS ────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Desktop.ini
Thumbs.db
